---
import NavLink from "@/components/navigation/nav-link.astro";

interface Props {
	class?: string;
	href: URL | string;
}

const { class: className, ...rest } = Astro.props;
---

<NavLink
	{...rest}
	class:list={[
		"rounded inline-flex px-4 py-2 font-medium transition hover:text-neutral-950 dark:hover:text-neutral-0",
		className,
	]}
	data-nav-link
>
	<slot />
</NavLink>
