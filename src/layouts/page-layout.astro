---
import "tailwindcss/tailwind.css";
import "@fontsource-variable/inter/slnt.css";
import "@/styles/index.css";

import SkipLink from "@/components/skip-link.astro";
import WebsiteFooter from "@/components/website-footer.astro";
import WebsiteHeader from "@/components/website-header.astro";
import type { Locale } from "@/config/i18n.config";
import DocumentLayout from "@/layouts/document-layout.astro";

interface Props {
	description?: string;
	locale?: Locale;
	robots?: string;
	title: string;
}

const { description, locale, robots, title } = Astro.props;
---

<DocumentLayout description={description} locale={locale} robots={robots} title={title}>
	<SkipLink />

	<div
		class="mx-auto grid min-h-full max-w-screen-lg grid-rows-[auto_1fr_auto] border-x bg-neutral-0 dark:bg-neutral-900"
	>
		<WebsiteHeader />
		<slot />
		<WebsiteFooter />
	</div>
</DocumentLayout>
